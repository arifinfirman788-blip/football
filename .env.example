# 默认不配置时会走相对路径 `./`，更适合微信小程序 web-view 嵌入。
# 如果明确部署在固定子路径下，例如 https://username.github.io/football/，可改成 /football/
VITE_BASE_PATH="./"

# 问答预测页使用的 Ark Bot 接口
VITE_ARK_API_URL="https://ark.cn-beijing.volces.com/api/v3/bots/chat/completions"
VITE_ARK_BOT_MODEL="bot-20260529180527-29f2t"
VITE_ARK_API_KEY=""
